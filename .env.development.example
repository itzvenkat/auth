# ─── Development Environment ─────────────────────────────────────────────────
# Copy to .env.development and fill in your local values
# Values here OVERRIDE .env for the development environment

NODE_ENV=development
PORT=3000

# App
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:4200
# Multiple origins (comma-separated) — used when this service is shared across several apps
# Supports exact origins and wildcard subdomains: *.mycompany.com
CORS_ORIGINS=http://localhost:4200,http://localhost:3001,http://localhost:5173

# Database (uses Docker Compose postgres by default)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=authuser
DB_PASSWORD=authpass
DB_DATABASE=authdb

# JWT — use any string for local dev
JWT_ACCESS_SECRET=dev-access-secret-change-in-prod
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-prod
JWT_REFRESH_EXPIRY=7d

# Email — Mailhog (starts automatically with docker-compose up)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_SECURE=false
SMTP_FROM="Auth Service" <noreply@auth.local>
# SMTP_USER and SMTP_PASS not needed for Mailhog

# Google OAuth (optional — leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# Security
BCRYPT_SALT_ROUNDS=10
MAX_LOGIN_ATTEMPTS=10
LOCK_TIME_MINUTES=5
TOTP_APP_NAME=AuthService (Dev)

# Rate limiting (relaxed for dev)
THROTTLE_TTL=60
THROTTLE_LIMIT=1000
