# ─── Production Environment ───────────────────────────────────────────────────
# Copy to .env.production and fill in production values
# NEVER commit this file — it's in .gitignore
# Values here OVERRIDE .env for the production environment

NODE_ENV=production
PORT=3000

# App
APP_URL=https://auth.yourdomain.com
FRONTEND_URL=https://yourdomain.com

# Database
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=CHANGE_ME
DB_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
DB_DATABASE=authdb
# DB_SSL=true  # uncomment if using SSL

# JWT — MUST be long random strings in production
# Generate: openssl rand -hex 64
JWT_ACCESS_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_64
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_64
JWT_REFRESH_EXPIRY=7d

# Email (production SMTP — e.g. SendGrid, Mailgun, Gmail)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=apikey
SMTP_PASS=CHANGE_ME_YOUR_SMTP_API_KEY
SMTP_FROM="Auth Service" <noreply@yourdomain.com>

# Google OAuth
GOOGLE_CLIENT_ID=CHANGE_ME
GOOGLE_CLIENT_SECRET=CHANGE_ME

# Security (stricter in production)
BCRYPT_SALT_ROUNDS=12
MAX_LOGIN_ATTEMPTS=5
LOCK_TIME_MINUTES=15
TOTP_APP_NAME=AuthService

# Rate limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100
