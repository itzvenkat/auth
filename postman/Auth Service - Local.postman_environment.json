{
    "id": "auth-service-local",
    "name": "Auth Service - Local",
    "values": [
        {
            "key": "baseUrl",
            "value": "http://localhost:3000",
            "type": "default",
            "enabled": true
        },
        {
            "key": "accessToken",
            "value": "",
            "type": "secret",
            "enabled": true,
            "description": "Auto-populated by the Login / 2FA Login / Refresh requests"
        },
        {
            "key": "refreshToken",
            "value": "",
            "type": "secret",
            "enabled": true,
            "description": "Auto-populated by the Login / 2FA Login / Refresh requests"
        },
        {
            "key": "userId",
            "value": "",
            "type": "default",
            "enabled": true,
            "description": "Auto-populated from the Login response"
        },
        {
            "key": "targetUserId",
            "value": "",
            "type": "default",
            "enabled": true,
            "description": "Populated by List Users — used in admin endpoints"
        },
        {
            "key": "sessionId",
            "value": "",
            "type": "default",
            "enabled": true,
            "description": "Auto-populated by List Sessions"
        },
        {
            "key": "apiKey",
            "value": "",
            "type": "secret",
            "enabled": true,
            "description": "Auto-populated when you Create API Key — only shown once!"
        },
        {
            "key": "apiKeyId",
            "value": "",
            "type": "default",
            "enabled": true,
            "description": "Auto-populated when you Create or List API Keys"
        },
        {
            "key": "emailVerificationToken",
            "value": "",
            "type": "default",
            "enabled": true,
            "description": "Paste from Mailhog (http://localhost:8025) after registering"
        },
        {
            "key": "passwordResetToken",
            "value": "",
            "type": "default",
            "enabled": true,
            "description": "Paste from Mailhog after calling Forgot Password"
        },
        {
            "key": "backupCodes",
            "value": "",
            "type": "secret",
            "enabled": true,
            "description": "Auto-populated after verifying 2FA setup — store securely!"
        }
    ],
    "_postman_variable_scope": "environment",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/environment.json"
}