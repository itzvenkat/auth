                        }
                    }
                },
                {
                    "name": "Change Password",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/auth/change-password",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "change-password"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"currentPassword\": \"MyStr0ng!Pass\",\n  \"newPassword\": \"NewStr0ng!Pass\",\n  \"confirmPassword\": \"NewStr0ng!Pass\"\n}"
                        }
                    }
                }
            ]
        },
        {
            "name": "Two-Factor Auth (2FA)",
            "item": [
                {
                    "name": "Enable 2FA (get QR code)",
                    "request": {
                        "method": "POST",
                        "url": {
                            "raw": "{{baseUrl}}/auth/2fa/enable",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "2fa",
                                "enable"
                            ]
                        }
                    }
                },
                {
                    "name": "Verify 2FA Setup",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/auth/2fa/verify",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "2fa",
                                "verify"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"code\": \"123456\"\n}"
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 200', () => pm.response.to.have.status(200));",
                                    "const json = pm.response.json();",
                                    "if (json.backupCodes) {",
                                    "  pm.environment.set('backupCodes', JSON.stringify(json.backupCodes));",
                                    "  console.log('Backup codes saved — store these securely!');",
                                    "}"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Disable 2FA",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/auth/2fa/disable",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "2fa",
                                "disable"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"code\": \"123456\"\n}"
                        }
                    }
                },
                {
                    "name": "Login with 2FA",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/auth/2fa/login",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "2fa",
                                "login"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"email\": \"venkat@example.com\",\n  \"password\": \"MyStr0ng!Pass\",\n  \"totpCode\": \"123456\"\n}"
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const json = pm.response.json();",
                                    "if (json.accessToken) {",
                                    "  pm.environment.set('accessToken', json.accessToken);",
                                    "  pm.environment.set('refreshToken', json.refreshToken);",
                                    "}"
                                ]
                            }
                        }
                    ]
                }
            ]
        },
        {
            "name": "Social Login",
            "item": [
                {
                    "name": "Google OAuth — Initiate",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/auth/google",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "google"
                            ]
                        },
                        "description": "Open this URL in a browser — it redirects to Google's consent page.\nNot usable directly from Postman due to browser redirect requirement."
                    }
                },
                {
                    "name": "Google OAuth — Callback (manual test)",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/auth/google/callback?code=PASTE_CODE_HERE",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "google",
                                "callback"
                            ],
                            "query": [
                                {
                                    "key": "code",
                                    "value": "PASTE_CODE_HERE"
                                }
                            ]
                        },
                        "description": "Paste the `code` param from Google's redirect URL here."
                    }
                }
            ]
        },
        {
            "name": "Profile & Sessions",
            "item": [
                {
                    "name": "Get My Profile",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/auth/me",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "me"
                            ]
                        }
                    }
                },
                {
                    "name": "Update Profile",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/auth/me",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "me"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Venkat K\",\n  \"avatar\": \"https://cdn.example.com/avatar.jpg\"\n}"
                        }
                    }
                },
                {
                    "name": "List Sessions",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/auth/sessions",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "sessions"
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const sessions = pm.response.json();",
                                    "if (Array.isArray(sessions) && sessions.length > 0) {",
                                    "  pm.environment.set('sessionId', sessions[0].id);",
                                    "}"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Revoke Session",
                    "request": {
                        "method": "DELETE",
                        "url": {
                            "raw": "{{baseUrl}}/auth/sessions/{{sessionId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "sessions",
                                "{{sessionId}}"
                            ]
                        }
                    }
                },
                {
                    "name": "Revoke All Sessions",
                    "request": {
                        "method": "DELETE",
                        "url": {
                            "raw": "{{baseUrl}}/auth/sessions",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "sessions"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "API Keys",
            "item": [
                {
                    "name": "List API Keys",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/auth/api-keys",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "api-keys"
                            ]
                        }
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const keys = pm.response.json();",
                                    "if (Array.isArray(keys) && keys.length > 0) {",
                                    "  pm.environment.set('apiKeyId', keys[0].id);",
                                    "}"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Create API Key",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/auth/api-keys",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "api-keys"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"My Backend Service\",\n  \"scopes\": [\"users:read\", \"content:read\"]\n}"
                        },
                        "description": "⚠️ The full API key is only shown in the response once — copy it immediately."
                    },
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "pm.test('Status 201', () => pm.response.to.have.status(201));",
                                    "const json = pm.response.json();",
                                    "if (json.key) {",
                                    "  pm.environment.set('apiKey', json.key);",
                                    "  pm.environment.set('apiKeyId', json.id);",
                                    "  console.log('API key saved — this is shown only once!');",
                                    "}"
                                ]
                            }
                        }
                    ]
                },
                {
                    "name": "Use API Key (test auth)",
                    "request": {
                        "method": "GET",
                        "header": [
                            {
                                "key": "X-API-Key",
                                "value": "{{apiKey}}"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/auth/me",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "me"
                            ]
                        },
                        "auth": {
                            "type": "noauth"
                        },
                        "description": "Uses X-API-Key header instead of Bearer token."
                    }
                },
                {
                    "name": "Revoke API Key",
                    "request": {
                        "method": "DELETE",
                        "url": {
                            "raw": "{{baseUrl}}/auth/api-keys/{{apiKeyId}}",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "api-keys",
                                "{{apiKeyId}}"
                            ]
                        }
                    }
                }
            ]
        },
        {
            "name": "Token Introspection",
            "item": [
                {
                    "name": "Introspect Token",
                    "request": {
                        "method": "POST",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/auth/token/introspect",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "auth",
                                "token",
                                "introspect"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"token\": \"{{accessToken}}\"\n}"
                        },
                        "auth": {
                            "type": "noauth"
                        },
                        "description": "OIDC-compatible. Downstream services can validate tokens without knowing the JWT secret."
                    }
                }
            ]
        },
