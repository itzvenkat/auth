                                "{{targetUserId}}"
                            ]
                        }
                    }
                },
                {
                    "name": "Update User Status",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/admin/users/{{targetUserId}}/status",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "admin",
                                "users",
                                "{{targetUserId}}",
                                "status"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"status\": \"suspended\"\n}",
                            "options": {
                                "raw": {
                                    "language": "json",
                                    "description": "One of: active | suspended | locked | pending"
                                }
                            }
                        }
                    }
                },
                {
                    "name": "Assign Roles to User",
                    "request": {
                        "method": "PATCH",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "url": {
                            "raw": "{{baseUrl}}/admin/users/{{targetUserId}}/roles",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "admin",
                                "users",
                                "{{targetUserId}}",
                                "roles"
                            ]
                        },
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"roles\": [\"admin\", \"moderator\"]\n}"
                        }
                    }
                },
                {
                    "name": "Get Audit Logs",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/admin/audit-logs?page=1&limit=50",
                            "host": [
                                "{{baseUrl}}"
                            ],
                            "path": [
                                "admin",
                                "audit-logs"
                            ],
